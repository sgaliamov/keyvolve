{
  "1mode": "optimize",
  "-mode": "merge",
  "`mode": "evaluate",
  "_mode": "synthesise",

  "keyboard": "data/keyboard.json",
  "text": "data/synthesised",
  "layouts": "data/layouts.csv",

  "merge": {
    "input": "data/samples",
    "output": "data/samples/merged.txt"
  },

  "optimization": {
    "input": "data/layouts.csv",
    "output": "data/layouts.csv",
    "bigramSwitchPenalty": 3.0,
    "balancePenalty": 1.5,
    "alternationPenalty": 0.25,
    "rowSwitchPenalty": 0.25,
    "-blocked": [19],
    "allowed": {
      "e": [6, 7, 8]
    },
    "`allowed": {
      "t": [1, 2, 6, 7, 8],
      "h": [1, 2, 6, 7, 8, 13],
      "c": [1, 2, 6, 7, 8, 13],
      "a": [2, 6, 7, 8],
      "o": [2, 6, 7, 8],
      "i": [2, 6, 7, 8],
      "n": [1, 2, 6, 7, 8],
      "r": [2, 6, 7, 8],
      "s": [1, 2, 6, 7, 8]
    },
    "`rolls": ["th", "er"]
  },

  "ga": {
    "mutationRatio": 0.9,
    "populationSize": 128,
    "pools": 256,
    "randomRatio": 0.25,
    "seedMutation": 4
  },

  "synthesise": {
    "text": "data/samples/merged.txt",
    "output": "data/synthesised",
    "minFrequency": 0.00001,
    "target": 100000
  }
}

{
  "keyboard": "data/keyboard.json",

  "merge": {
    "input": "data/samples",
    "output": "data/samples/merged.txt",
    "shuffle": false,
    "print": 50
  },

  "synthesise": {
    "text": "data/samples/merged.txt",
    "output": "data/synthesised/markov",
    "method": "markov",
    "digraph": {
      "target": 64000,
      "maxWordLen": 5
    },
    "sample": {
      "target": 100000
    },
    "markov": {
      "target": 64000,
      "maxWordLen": 15,
      "attempts": 256
    }
  },

  "optimization": {
    "text": "data/synthesised/sample-1000000",
    "-input": "data/seed.csv",
    "output": "data/layouts.csv",
    "mutationCount": 10,
    "blocked": [0, 14, 25, 19],
    "_": {
      "r": [1, 2, 5, 6, 7, 8],
      "s": [1, 2, 5, 6, 7, 8],
      "j": [4, 10, 11],
      "q": [4, 10, 11],
      "h": [1, 2, 3],
      "a": [1, 2, 6, 7, 8],
      "i": [1, 2, 6, 7, 8],
      "o": [1, 2, 6, 7, 8],
      "n": [1, 2, 6, 7, 8],
      "v": [12, 13, 14]
    },
    "-frozen": {
      "h": 5,
      "i": 6,
      "a": 7,
      "t": 8,
      "c": 9,
      "m": 20,
      "n": 21,
      "e": 22,
      "o": 23,
      "r": 24
    },
    "-allowed": {
      "t": [1, 2],
      "e": [6, 7, 8]
    },
    "-rolls": ["er", "oe", "ai", "au", "it", "th", "ej", "xz"],
    "-left": ["a", "i", "n"],
    "--left": ["t", "h"],
    "-right": ["e", "r"]
  },

  "evaluate": {
    "text": "data\\synthesised\\sample-1000000",
    "=text": "data\\samples\\merged.txt",
    "input": "data/layouts.csv",
    "-input": "data/seed.csv",
    "output": "data/layouts.csv",
    "print": 10,
    "aSide": "left"
  },

  "evaluator": {
    "balancePenalty": 3.0,
    "rowSwitchPenalty": 0.75,
    "bigramSwitchPenalty": 1.0,
    "pinkyMultiplier": 1.0
  },

  "ga": {
    "mutationRatio": 0.6,
    "populationSize": 200,
    "pools": 250,
    "randomRatio": 0.25,
    "seedMutation": 10,
    "dump": "data/dump.bin",
    "dumpRatio": 0.8,
    "keepDump": false
  }
}

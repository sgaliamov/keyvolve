{
  "keyboard": "data/keyboard.json",

  "merge": {
    "input": "data/samples",
    "output": "data/samples/merged.txt",
    "shuffle": false,
    "print": 50
  },

  "synthesise": {
    "text": "data/samples/merged.txt",
    "output": "data/synthesised/markov",
    "method": "markov",
    "digraph": {
      "target": 64000,
      "maxWordLen": 5
    },
    "sample": {
      "target": 100000
    },
    "markov": {
      "target": 64000,
      "maxWordLen": 15,
      "attempts": 256
    }
  },

  "optimization": {
    "text": "data/synthesised/sample-20000",
    "-input": "data/seed.csv",
    "output": "data/layouts.csv",
    "mutationCount": 20,
    "blocked": [19],
    "allowed": {
      "t": [1, 2, 3, 6, 7, 8, 13],
      "h": [1, 2, 3, 6, 7, 8, 13],
      "c": [1, 2, 3, 6, 7, 8, 11, 12, 13],
      "e": [6, 7, 8],
      "a": [1, 2, 3, 6, 7, 8],
      "o": [1, 2, 3, 6, 7, 8],
      "r": [1, 2, 6, 7, 8],
      "s": [1, 2, 3, 6, 7, 8, 11, 12, 13]
    },
    "`allowed": {
      "i": [2, 6, 7, 8],
      "n": [1, 2, 6, 7, 8]
    },
    "rolls": ["ht", "er"]
  },

  "evaluate": {
    "text": "data\\synthesised\\sample-1000000",
    "input": "data/layouts.csv",
    "output": "data/layouts.csv",
    "print": 10
  },

  "evaluator": {
    "bigramSwitchPenalty": 3.0,
    "balancePenalty": 1.5,
    "alternationPenalty": 0.25,
    "rowSwitchPenalty": 0.5
  },

  "ga": {
    "mutationRatio": 0.9,
    "populationSize": 128,
    "pools": 512,
    "randomRatio": 0.25,
    "seedMutation": 4
  }
}

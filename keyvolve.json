{
  "mode": "optimize",
  "-mode": "merge",
  "_mode": "evaluate",
  "~mode": "synthesise",

  "merge": { "input": "data/samples", "output": "data/samples/merged.txt" },

  "optimization": {
    "output": "data/layouts.csv",
    "blocked": [19],
    "allowed": {
      "e": [6, 7, 8],
      "t": [1, 2, 3, 6, 7, 8, 13],
      "a": [2, 6, 7, 8],
      "o": [2, 6, 7, 8],
      "i": [1, 2, 3, 6, 7, 8],
      "n": [1, 2, 3, 6, 7, 8, 12, 13],
      "r": [2, 6, 7, 8],
      "s": [1, 2, 3, 6, 7, 8, 12, 13]
    },
    "-rolls": ["he", "in", "er", "an", "en", "it"]
  },

  "keyboard": "data/keyboard.json",
  "layouts": "data/layouts.csv",
  "text": "data/synthesised",
  "ga": {
    "mutationRatio": 0.75,
    "populationSize": 128,
    "pools": 256,
    "randomRatio": 0.25
  },
  "synthesise": {
    "output": "data/synthesised",
    "minFrequency": 0.00001,
    "target": 100000
  }
}

{
  "keyboard": "data/keyboard.json",

  "merge": {
    "input": "data/samples",
    "output": "data/samples/merged.txt",
    "shuffle": false,
    "print": 50
  },

  "synthesise": {
    "text": "data/samples/merged.txt",
    "output": "data/synthesised/markov",
    "method": "markov",
    "digraph": {
      "target": 64000,
      "maxWordLen": 5
    },
    "sample": {
      "target": 100000
    },
    "markov": {
      "target": 64000,
      "maxWordLen": 15,
      "attempts": 256
    }
  },

  "optimization": {
    "text": "data/synthesised/sample-100000",
    "input": "data/seed.csv",
    "output": "data/layouts.csv",
    "mutationCount": 10,
    "blocked": [19],
    "allowed": {
      "t": [1, 2, 3],
      "h": [1, 2, 3],
      "e": [6, 7, 8],
      "a": [1, 2, 3, 6, 7, 8],
      "o": [1, 2, 3, 6, 7, 8],
      "i": [1, 2, 3, 6, 7, 8],
      "r": [6, 7, 8],
      "s": [1, 2, 6, 7, 8]
    },
    "`allowed": {
      "c": [1, 2, 3, 6, 7, 8, 11, 12, 13],
      "n": [1, 2, 6, 7, 8]
    },
    "rolls": ["ht", "er", "in"]
  },

  "evaluate": {
    "text": "data\\synthesised\\sample-1000000",
    "input": "data/layouts.csv",
    "output": "data/layouts.csv",
    "print": 10
  },

  "evaluator": {
    "bigramSwitchPenalty": 3.0,
    "balancePenalty": 1.5,
    "alternationPenalty": 0.25,
    "rowSwitchPenalty": 0.5,
    "pinkyMultiplier": 1.0
  },

  "ga": {
    "mutationRatio": 0.6,
    "populationSize": 100,
    "pools": 50,
    "randomRatio": 0.25,
    "seedMutation": 4,
    "dump": "data/dump.bin",
    "dumpRatio": 0.8,
    "keepDump": true
  }
}

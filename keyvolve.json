{
  "keyboard": "data/keyboard.json",

  "merge": {
    "input": "data/samples",
    "output": "data/samples/merged.txt",
    "shuffle": false,
    "print": 50
  },

  "synthesise": {
    "text": "data/samples/merged.txt",
    "output": "data/synthesised/markov",
    "method": "markov",
    "digraph": {
      "target": 64000,
      "maxWordLen": 5
    },
    "sample": {
      "target": 100000
    },
    "markov": {
      "target": 64000,
      "maxWordLen": 15,
      "attempts": 256
    }
  },

  "optimization": {
    "text": "data/synthesised/sample-1000000",
    "-input": "data/seed.csv",
    "output": "data/layouts.csv",
    "mutationCount": 10,
    "blocked": [0, 14, 15, 19],
    "_": {
      "x": 11,
      "z": 10,
      "e": [6, 7, 8],
      "t": [1, 2],
      "a": [1, 2, 6, 7, 8],
      "i": [1, 2, 6, 7, 8],
      "o": [1, 2, 6, 7, 8],
      "n": [1, 2, 6, 7, 8],
      "r": [1, 2, 5, 6, 7, 8],
      "s": [1, 2, 5, 6, 7, 8],
      "h": [1, 2, 3],
      "v": [12, 13, 14]
    },
    "-frozen": {
      "e": 7
    },
    "-allowed": {
      "j": [0, 4, 10, 11, 14],
      "q": [0, 4, 10, 11, 14]
    },
    "rolls": ["ht", "er", "in"]
  },

  "evaluate": {
    "text": "data\\synthesised\\sample-1000000",
    "=text": "data\\samples\\merged.txt",
    "input": "data/layouts.csv",
    "-input": "data/seed.csv",
    "output": "data/layouts.csv",
    "print": 10,
    "aSide": "left"
  },

  "evaluator": {
    "balancePenalty": 2.0,
    "rowSwitchPenalty": 0.75,
    "pinkyMultiplier": 1.0,
    "bigramSwitchPenalty": 1.0,
    "alternationPenalty": 5.0
  },

  "ga": {
    "mutationRatio": 0.6,
    "populationSize": 200,
    "pools": 250,
    "randomRatio": 0.25,
    "seedMutation": 10,
    "dump": "data/dump.bin",
    "dumpRatio": 0.8,
    "keepDump": false
  }
}

{
  "mode": "optimize",
  "-mode": "merge",
  "_mode": "evaluate",
  "~mode": "synthesise",

  "keyboard": "data/keyboard.json",
  "-layouts": "data/layouts.csv",
  "text": "data/synthesised",

  "merge": { "input": "data/samples", "output": "data/samples/merged.txt" },

  "optimization": {
    "output": "data/layouts.csv",
    "bigramSwitchPenalty": 1.5,
    "balancePenalty": 1.5,
    "alternationPenalty": 0.25,
    "-blocked": [19],
    "-allowed": {
      "e": [6, 7, 8],
      "t": [1, 2, 3],
      "a": [2, 6, 7, 8],
      "o": [2, 6, 7, 8],
      "i": [1, 2, 3, 6, 7, 8],
      "n": [1, 2, 3, 6, 7, 8, 12, 13],
      "r": [2, 6, 7, 8],
      "s": [1, 2, 3, 6, 7, 8, 12, 13],
      "h": [1, 2, 3],
      "c": [1, 2, 3],
      "k": [11, 12, 13],
      "l": [11, 12, 13],
      "y": [11, 12, 13]
    },
    "-rolls": ["th", "er"]
  },

  "ga": {
    "mutationRatio": 0.9,
    "populationSize": 128,
    "pools": 256,
    "randomRatio": 0.25
  },

  "synthesise": {
    "output": "data/synthesised",
    "minFrequency": 0.00001,
    "target": 100000
  }
}
